# Application
APP_NAME="AI Investigation Assistant"
APP_VERSION="1.0.0"
DEBUG=False
ENVIRONMENT=production

# Server
HOST=0.0.0.0
PORT=8000

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=ai_investigation_db

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Grok API (xAI)
GROK_API_KEY=your-grok-api-key-here
GROK_API_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-beta

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# FAISS Vector Store
FAISS_INDEX_PATH=./app/vector_store/faiss_index
FAISS_INDEX_NAME=legal_docs_index

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,txt

# Reports
REPORTS_DIR=./reports

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Admin Default Credentials (change immediately after first run)
ADMIN_EMAIL=admin@investigation.gov
ADMIN_PASSWORD=Admin@123456
ADMIN_FULL_NAME=System Administrator
